                <textFieldExpression><![CDATA["For " + ($P{CompanyName} == null ? "" : $P{CompanyName})]]></textFieldExpression>
            </textField>

            <!-- Amount in Words -->
            <rectangle>
                <reportElement x="0" y="120" width="555" height="22" backcolor="#FFFDE7" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#FFE082"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="6" y="122" width="85" height="18"/>
                <textElement verticalAlignment="Middle"><font size="7" isBold="true"/></textElement>
                <text><![CDATA[Amount in Words:]]></text>
