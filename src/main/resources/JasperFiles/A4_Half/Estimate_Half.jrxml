            <textField isBlankWhenNull="true">
                <reportElement x="469" y="0" width="40" height="16"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="6"/></textElement>
                <textFieldExpression><![CDATA[$F{sub_total}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="509" y="0" width="46" height="16"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="6"/></textElement>
                <textFieldExpression><![CDATA[$F{total}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- ========================= SUMMARY ========================= -->
    <summary>
        <band height="200">
            <!-- Total items row -->
            <rectangle>
                <reportElement x="0" y="0" width="555" height="16" backcolor="#EDF0F5" mode="Opaque"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <line><reportElement x="0" y="0" width="555" height="1" forecolor="#CCCCCC"/></line>
            <textField>
                <reportElement x="15" y="0" width="160" height="16"/>
                <textElement verticalAlignment="Middle"><font size="6" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["Total: " + $V{REPORT_COUNT} + " item(s)"]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0">
                <reportElement x="120" y="0" width="28" height="16"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="6" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{TotalQty}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="509" y="0" width="46" height="16"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="6" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{TotalAmount}]]></textFieldExpression>
            </textField>
            <line><reportElement x="0" y="16" width="555" height="1" forecolor="#CCCCCC"/></line>

            <!-- TAX DETAILS box (left) -->
            <rectangle>
                <reportElement x="0" y="20" width="265" height="95" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#CCCCCC"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="6" y="23" width="253" height="11" forecolor="#1E2D4D"/>
                <textElement><font size="7" isBold="true"/></textElement>
                <text><![CDATA[TAX DETAILS]]></text>
            </staticText>
            <line><reportElement x="6" y="35" width="253" height="1" forecolor="#E0E0E0"/></line>
            <staticText>
                <reportElement x="6" y="38" width="110" height="11" forecolor="#888888"/>
                <textElement><font size="7"/></textElement>
                <text><![CDATA[Taxable Amount]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="120" y="38" width="139" height="11"/>
                <textElement textAlignment="Right"><font size="7"/></textElement>
                <textFieldExpression><![CDATA["Rs." + ($P{TotalAmountBeforeTaxStr} == null ? "0.00" : $P{TotalAmountBeforeTaxStr})]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="6" y="51" width="110" height="11" forecolor="#888888"/>
                <textElement><font size="7"/></textElement>
                <text><![CDATA[CGST]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="120" y="51" width="139" height="11"/>
                <textElement textAlignment="Right"><font size="7"/></textElement>
                <textFieldExpression><![CDATA["Rs." + ($P{CGSTAmountStr} == null ? "0.00" : $P{CGSTAmountStr})]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="6" y="64" width="110" height="11" forecolor="#888888"/>
                <textElement><font size="7"/></textElement>
                <text><![CDATA[SGST]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="120" y="64" width="139" height="11"/>
                <textElement textAlignment="Right"><font size="7"/></textElement>
                <textFieldExpression><![CDATA["Rs." + ($P{SGSTAmountStr} == null ? "0.00" : $P{SGSTAmountStr})]]></textFieldExpression>
            </textField>
            <line><reportElement x="6" y="77" width="253" height="1" forecolor="#2255CC"/></line>
            <staticText>
                <reportElement x="6" y="80" width="110" height="12"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[GRAND TOTAL]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="120" y="80" width="139" height="12"/>
                <textElement textAlignment="Right"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["Rs." + ($P{GrandTotalStr} == null ? "0.00" : $P{GrandTotalStr})]]></textFieldExpression>
            </textField>

            <!-- AMOUNT SUMMARY box (right) with signature -->
            <rectangle>
                <reportElement x="275" y="20" width="280" height="95" backcolor="#FFFFFF" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#CCCCCC"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="281" y="23" width="268" height="11" forecolor="#1E2D4D"/>
                <textElement><font size="7" isBold="true"/></textElement>
                <text><![CDATA[AMOUNT SUMMARY]]></text>
            </staticText>
            <line><reportElement x="281" y="35" width="268" height="1" forecolor="#E0E0E0"/></line>
            <staticText>
                <reportElement x="281" y="38" width="120" height="11" forecolor="#888888"/>
                <textElement><font size="7"/></textElement>
                <text><![CDATA[Taxable Amount]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="405" y="38" width="144" height="11"/>
                <textElement textAlignment="Right"><font size="7"/></textElement>
                <textFieldExpression><![CDATA["Rs." + ($P{TotalAmountBeforeTaxStr} == null ? "0.00" : $P{TotalAmountBeforeTaxStr})]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="281" y="51" width="120" height="11" forecolor="#888888"/>
                <textElement><font size="7"/></textElement>
                <text><![CDATA[Tax (GST)]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="405" y="51" width="144" height="11"/>
                <textElement textAlignment="Right"><font size="7"/></textElement>
                <textFieldExpression><![CDATA["Rs." + ($P{TaxAmountGSTStr} == null ? "0.00" : $P{TaxAmountGSTStr})]]></textFieldExpression>
            </textField>
            <line><reportElement x="281" y="64" width="268" height="1" forecolor="#2255CC"/></line>
            <staticText>
                <reportElement x="281" y="67" width="120" height="12"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[GRAND TOTAL]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="405" y="67" width="144" height="12"/>
                <textElement textAlignment="Right"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["Rs." + ($P{GrandTotalStr} == null ? "0.00" : $P{GrandTotalStr})]]></textFieldExpression>
            </textField>
            <!-- Signature area -->
            <line><reportElement x="281" y="85" width="268" height="1" forecolor="#CCCCCC"/></line>
            <staticText>
                <reportElement x="281" y="88" width="268" height="10" forecolor="#888888"/>
