                        <reportElement x="90" y="20" width="300" height="40"/>
                        <textElement textAlignment="Left">
                            <font size="10"/>
                        </textElement>
                        <text><![CDATA[Elangkavu, vadayar, vaikom
        Contact : 8078311945
        GSTIN : 
        Email ID : info@raintechpos.com]]></text>
                    </staticText>
        </band>
