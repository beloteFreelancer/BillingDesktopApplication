    <!-- Title (Header) -->
    <title>
        <band height="100">
            <!-- Logo -->
            <image>
                <reportElement x="0" y="0" width="80" height="40"/>
                <imageExpression><![CDATA[$P{CompanyLogo}]]></imageExpression>
            </image>
            <!-- Company Name -->
                    <staticText>
                        <reportElement x="90" y="0" width="300" height="20"/>
