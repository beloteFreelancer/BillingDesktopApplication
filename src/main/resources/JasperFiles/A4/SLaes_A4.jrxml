            <staticText><reportElement x="0" y="0" width="30" height="20"/><textElement textAlignment="Center" isBold="true"/><text><![CDATA[S.No]]></text></staticText>
            <staticText><reportElement x="30" y="0" width="120" height="20"/><textElement textAlignment="Center" isBold="true"/><text><![CDATA[Product Name]]></text></staticText>
            <staticText><reportElement x="150" y="0" width="50" height="20"/><textElement textAlignment="Center" isBold="true"/><text><![CDATA[Size]]></text></staticText>
            <staticText><reportElement x="200" y="0" width="50" height="20"/><textElement textAlignment="Center" isBold="true"/><text><![CDATA[Qty]]></text></staticText>
            <staticText><reportElement x="250" y="0" width="50" height="20"/><textElement textAlignment="Center" isBold="true"/><text><![CDATA[MRP]]></text></staticText>
            <staticText><reportElement x="300" y="0" width="60" height="20"/><textElement textAlignment="Center" isBold="true"/><text><![CDATA[Disc Amt]]></text></staticText>
            <staticText><reportElement x="360" y="0" width="60" height="20"/><textElement textAlignment="Center" isBold="true"/><text><![CDATA[Rate]]></text></staticText>
