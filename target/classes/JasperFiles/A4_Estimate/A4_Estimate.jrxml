                <textElement textAlignment="Right"><font size="8"/></textElement>
                <textFieldExpression><![CDATA["Rs. " + ($P{TaxAmountGSTStr} == null ? "0.00" : $P{TaxAmountGSTStr})]]></textFieldExpression>
            </textField>
            <!-- Blue separator -->
            <line>
                <reportElement x="281" y="84" width="267" height="1" forecolor="#2255CC"/>
            </line>
            <!-- GRAND TOTAL bold -->
            <staticText>
                <reportElement x="281" y="87" width="150" height="16"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[GRAND TOTAL]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="435" y="87" width="113" height="16"/>
                <textElement textAlignment="Right"><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["Rs. " + ($P{GrandTotalStr} == null ? "0.00" : $P{GrandTotalStr})]]></textFieldExpression>
            </textField>
            <!-- Signature line -->
            <line>
                <reportElement x="291" y="152" width="247" height="1" forecolor="#CCCCCC"/>
            </line>
            <staticText>
                <reportElement x="281" y="155" width="267" height="13" forecolor="#888888"/>
                <textElement textAlignment="Center"><font size="8"/></textElement>
                <text><![CDATA[Authorised Signatory]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="281" y="170" width="267" height="13"/>
                <textElement textAlignment="Center"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["For " + ($P{CompanyName} == null ? "" : $P{CompanyName})]]></textFieldExpression>
            </textField>

            <!-- ============ Amount in Words ============ -->
            <rectangle>
                <reportElement x="0" y="220" width="555" height="28" backcolor="#FFFDE7" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#FFE082"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="8" y="222" width="120" height="22"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Amount in Words:]]></text>
            </staticText>
            <textField evaluationTime="Report" isBlankWhenNull="true">
                <reportElement x="132" y="222" width="416" height="22"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$P{AmountInWords}]]></textFieldExpression>
            </textField>

            <!-- ============ Terms and Conditions ============ -->
            <staticText>
                <reportElement x="0" y="255" width="555" height="14"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[TERMS AND CONDITIONS]]></text>
            </staticText>
            <textField isStretchWithOverflow="true" isBlankWhenNull="true">
                <reportElement x="0" y="271" width="555" height="68"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$P{TermsAndConditions}]]></textFieldExpression>
            </textField>

            <!-- ============ Footer bar ============ -->
            <rectangle>
                <reportElement x="0" y="346" width="555" height="14" backcolor="#1E2D4D" mode="Opaque"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="346" width="555" height="14" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="7"/>
